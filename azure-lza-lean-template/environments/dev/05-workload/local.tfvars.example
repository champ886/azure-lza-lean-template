# Copy to local.tfvars and fill in — never commit local.tfvars
# Get storage account ID:
# az storage account show --name cctfstate --resource-group YOUR_ORG_PREFIX-tfstate-platform --query id -o tsv
flow_log_storage_account_id = "/subscriptions/YOUR_PLATFORM_SUBSCRIPTION_ID/resourceGroups/YOUR_ORG_PREFIX-tfstate-platform/providers/Microsoft.Storage/storageAccounts/cctfstate"
